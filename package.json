{
  "name": "catclaw",
  "version": "1.0.0",
  "description": "Lightweight Discord → Claude CLI bridge via ACP protocol",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/skills/builtin-prompt','dist/skills/builtin-prompt',{recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "pm2:start": "pm2 start dist/index.js --name catclaw",
    "pm2:restart": "tsc && pm2 restart catclaw",
    "pm2:stop": "pm2 stop catclaw",
    "pm2:logs": "pm2 logs catclaw",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.1",
    "@mariozechner/pi-agent-core": "0.58.0",
    "@mariozechner/pi-ai": "0.58.0",
    "apache-arrow": "^18.1.0",
    "croner": "^10.0.1",
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pm2": "^6.0.14",
    "typescript": "^5.7.2"
  }
}
