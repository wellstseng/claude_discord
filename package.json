{
  "name": "catclaw",
  "version": "1.0.0",
  "description": "Lightweight Discord → Claude CLI bridge via ACP protocol",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/skills/builtin-prompt dist/skills/builtin-prompt",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "pm2:start": "pm2 start dist/index.js --name catclaw",
    "pm2:restart": "tsc && pm2 restart catclaw",
    "pm2:stop": "pm2 stop catclaw",
    "pm2:logs": "pm2 logs catclaw",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "croner": "^10.0.1",
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "pm2": "^6.0.14",
    "typescript": "^5.7.2"
  }
}
