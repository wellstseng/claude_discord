# Discord Bot Token（必填，從 Discord Developer Portal 取得）
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# 觸發模式：mention（需 @mention bot）或 all（白名單頻道內所有訊息）
# 預設：mention
TRIGGER_MODE=mention

# 允許的頻道 ID，逗號分隔。空白 = 全部頻道允許
# 範例：ALLOWED_CHANNEL_IDS=123456789,987654321
ALLOWED_CHANNEL_IDS=

# Claude session 工作目錄（spawn 的 cwd）
# 預設：$HOME
CLAUDE_CWD=

# claude CLI binary 路徑（若非 PATH 標準位置才需指定）
# 預設：claude
CLAUDE_COMMAND=claude

# Debounce 毫秒數（同一人連續訊息的合併等待時間）
# 預設：500
DEBOUNCE_MS=500
