// catclaw 設定檔範本（JSONC 格式，支援 // 註解）
// 複製此檔為 config.json 後修改
{
  // ── Discord 連線與權限 ─────────────────────────────────────────
  "discord": {
    // Discord Bot Token（從 Developer Portal 取得）
    "token": "your_discord_bot_token_here",

    // DM 私訊設定
    // 注意：bot 間的 DM 永遠禁止（防止 bot 互敲迴圈）
    "dm": {
      "enabled": true          // 是否回應 DM 私訊
    },

    // Per-guild 權限設定
    // 頻道/討論串未列在 channels 中時，自動繼承 guild 預設值
    // 繼承鏈：Thread → Parent Channel → Guild 預設
    "guilds": {
      "123456789012345678": {
        // ── Guild 預設值（所有未列 channel 繼承這組）──
        "allow": true,           // 是否允許回應（false = 整個 guild 靜默）
        "requireMention": true,  // 是否需要 @bot 才觸發
        "allowBot": false,       // 是否處理其他 bot 的訊息
        "allowFrom": [],         // 白名單 user/bot ID（空陣列 = 不限制）

        // ── Per-channel 覆寫（只需列出要覆寫的欄位）──
        "channels": {
          // 範例：這個頻道不需要 @mention，其餘繼承 guild 預設
          "111111111111111111": {
            "allow": true,
            "requireMention": false
          },

          // 範例：這個頻道允許特定 bot，且只聽白名單內的 ID
          "222222222222222222": {
            "allow": true,
            "requireMention": true,
            "allowBot": true,
            "allowFrom": ["333333333333333333"]
          }
        }
      }
    }
  },

  // ── Claude CLI ─────────────────────────────────────────────────
  "claude": {
    "cwd": "",                   // Claude session 工作目錄（空字串 = $HOME）
    "command": "claude",         // Claude CLI 執行檔路徑
    "turnTimeoutMs": 300000,     // 單次回應超時（毫秒），預設 5 分鐘
    "sessionTtlHours": 168       // Session 閒置超時（小時），預設 7 天
  },

  // ── 全域設定 ───────────────────────────────────────────────────
  "showToolCalls": "summary",    // 工具呼叫顯示：all（完整）/ summary（僅「處理中」）/ none（隱藏）
  "showThinking": false,         // 是否顯示 Claude 推理過程（thinking block）
  "debounceMs": 500,             // 同一人訊息合併延遲（毫秒）
  "fileUploadThreshold": 4000,   // 回覆超過此字數時上傳為 .md 檔（0 = 停用）
  "logLevel": "info"             // 日誌層級：debug / info / warn / error / silent
}
