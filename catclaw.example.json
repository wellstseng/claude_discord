// catclaw 設定檔範本（JSONC 格式，支援 // 註解）
// 複製此檔為 ~/.catclaw/catclaw.json 後修改
// 路徑控制請改用環境變數（CATCLAW_CONFIG_DIR / CATCLAW_WORKSPACE / CATCLAW_CLAUDE_BIN）
{
  // ── Discord 連線與權限 ─────────────────────────────────────────
  "discord": {
    // Discord Bot Token（從 Developer Portal 取得）
    "token": "",

    // DM 私訊設定
    "dm": {
      "enabled": true
    },

    // Per-guild / per-channel 權限設定
    // 繼承鏈：Thread → Parent Channel → Guild 預設
    "guilds": {
      // "<你的 Guild ID>": {
      //   "allow": true,
      //   "requireMention": true,
      //   "allowBot": false,
      //   "allowFrom": [],
      //   "blockGroupMentions": false,
      //   "channels": {
      //     "<頻道 ID>": {
      //       "allow": true,
      //       "requireMention": false,
      //       "allowBot": false,
      //       "blockGroupMentions": false,
      //       "autoThread": false
      //     },
      //     // autoThread: 每條訊息自動建立 Thread（適合多人討論頻道）
      //     "<thread 頻道 ID>": { "allow": true, "requireMention": false, "autoThread": true }
      //   }
      // }
    }
  },

  // ── 管理員（slash commands 權限）─────────────────────────────
  // 允許執行 /restart /reset-session /status 的 Discord user ID
  // 空陣列 = 拒絕所有人（建議至少填入自己的 ID）
  "admin": {
    "allowedUserIds": []
  },

  // ── 全域基本設定 ───────────────────────────────────────────────
  "turnTimeoutMs": 300000,            // 單回合逾時（毫秒），預設 5 分鐘
  "turnTimeoutToolCallMs": 480000,    // tool_call 時延長逾時（毫秒），預設 8 分鐘
  "showToolCalls": "none",            // all / summary / none
  "showThinking": false,
  "debounceMs": 500,
  "fileUploadThreshold": 4000,        // 超過此字數改以 .md 附件上傳（0 = 停用）
  "streamingReply": true,
  "logLevel": "debug",                // debug / info / warn / error / silent

  // ── 排程（Cron）────────────────────────────────────────────────
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1,
    "defaultAccountId": "_cron",
    "defaultProvider": "claude-oauth"
    // "jobs": [] 亦可放此處（若未使用 data/cron-jobs.json）
  },

  // ── History（inbound / outbound 歷史記錄開關）─────────────────
  "history": {
    "enabled": true
  },

  // ══════════════════════════════════════════════════════════════
  // V2 三層分離設定（推薦）
  // 格式：<provider>/<model>，如 "anthropic/claude-sonnet-4-6"
  // 認證放 auth-profile.json，模型目錄自動從內建 + 自訂合併
  // ══════════════════════════════════════════════════════════════

  // ── Agent 預設模型 ────────────────────────────────────────────
  "agentDefaults": {
    "model": {
      "primary": "sonnet"
    },
    // 模型對照表：key = "provider/model"，alias = 簡短名
    "models": {
      "anthropic/claude-opus-4-6":            { "alias": "opus" },
      "anthropic/claude-sonnet-4-6":          { "alias": "sonnet" },
      "anthropic/claude-haiku-4-5-20251001":  { "alias": "haiku" },
      "ollama/qwen3:14b":                     { "alias": "qwen3" },
      "ollama/gemma4:latest":                 { "alias": "gemma" },
      "openai-codex/gpt-5.4":                 { "alias": "codex" },
      "openai/gpt-4o":                        { "alias": "gpt4o" },
      "cli-claude/claude":                    { "alias": "cli-claude" },
      "cli-gemini/gemini":                    { "alias": "cli-gemini" }
    }
  },

  // ── 自訂 Provider 目錄（與內建合併）─────────────────────────
  // 內建：anthropic、openai、openai-codex（自動載入）
  // mode = "merge" 與內建合併；此處新增的 provider 可在 agentDefaults.models 引用
  "modelsConfig": {
    "mode": "merge",
    "providers": {
      "cli-claude": {
        "baseUrl": "",
        "models": [
          {
            "id": "claude",
            "name": "Claude CLI (Max Plan)",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 200000,
            "maxTokens": 16000
          }
        ]
      },
      "cli-gemini": {
        "baseUrl": "",
        "models": [
          {
            "id": "gemini",
            "name": "Gemini CLI (Pro Plan)",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 1000000,
            "maxTokens": 32000
          }
        ]
      },
      "openai-codex": {
        "baseUrl": "https://chatgpt.com/backend-api",
        "api": "openai-codex-responses",
        "models": []
      },
      "ollama": {
        "baseUrl": "http://localhost:11434",
        "api": "ollama",
        "models": [
          {
            "id": "qwen3:14b",
            "name": "Qwen3 14B",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 4096
          },
          {
            "id": "gemma4:latest",
            "name": "Gemma 4 12B",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  // ══════════════════════════════════════════════════════════════
  // V1 舊格式（保留相容，若有 agentDefaults 則以 V2 優先）
  // ══════════════════════════════════════════════════════════════
  "provider": "ollama-local",
  "providers": {
    "ollama-local": {
      "type": "ollama",
      "host": "http://localhost:11434",
      "model": "qwen3:1.7b"
    }
  },

  // ── Provider / Model 路由 ──────────────────────────────────────
  // 優先序：channels > projects > roles > default
  "providerRouting": {
    "channels": {},
    "roles": {
      "default": "ollama-local"
    },
    "projects": {}
  },
  "modelRouting": {
    "default": "sonnet"
  },

  // ── Session 持久化 ────────────────────────────────────────────
  "session": {
    "ttlHours": 168,
    "maxHistoryTurns": 50,
    "compactAfterTurns": 30,
    "persistPath": "~/.catclaw/workspace/data/sessions/"
  },

  // ── 記憶系統 ──────────────────────────────────────────────────
  "memory": {
    "enabled": true,
    "root": "",                           // 空字串 = 用 CATCLAW_WORKSPACE
    "vectorDbPath": "~/.catclaw/_vectordb",
    "contextBudget": 3000,
    "contextBudgetRatio": { "global": 1, "project": 1, "account": 1 },
    "writeGate": { "enabled": true, "dedupThreshold": 0.8 },
    "recall": {
      "triggerMatch": true,
      "vectorSearch": true,
      "relatedEdgeSpreading": true,
      "vectorMinScore": 0.35,
      "vectorTopK": 10,
      "llmSelect": false,
      "llmSelectMax": 5
    },
    "extract": {
      "enabled": true,
      "perTurn": true,
      "onSessionEnd": true,
      "maxItemsPerTurn": 3,
      "maxItemsSessionEnd": 5,
      "accumCharThreshold": 200,
      "accumTurnThreshold": 5,
      "cooldownMs": 120000
    },
    "consolidate": {
      "autoPromoteThreshold": 3,
      "suggestPromoteThreshold": 4,
      "decay": {
        "enabled": true,
        "halfLifeDays": 14,
        "archiveThreshold": 0.2
      }
    },
    "episodic": { "enabled": true, "ttlDays": 24 },
    "rutDetection": { "enabled": true, "windowSize": 3, "minOccurrences": 2 },
    "oscillation": { "enabled": true },
    "sessionMemory": {
      "enabled": true,
      "intervalTurns": 10,
      "maxHistoryTurns": 15
    }
  },

  // ── 記憶管線（embedding / extraction / reranker 後端）────────
  // extraction provider: "ollama"（本地免費）/ "anthropic"（API，自動從 auth-profile 讀 key）/ "openai"
  // 沒有 Ollama 的環境建議用 "anthropic" + haiku 模型（低成本）
  "memoryPipeline": {
    "embedding":  { "provider": "ollama", "model": "qwen3-embedding:8b", "host": "http://localhost:11434" },
    "extraction": { "provider": "ollama", "model": "qwen3:14b",          "host": "http://localhost:11434" },
    "reranker":   { "provider": "none",   "model": "" }
  },

  // ── Ollama 本地後端（記憶管線用，與對話 LLM 用途不同）──────
  // providers.ollama-* = 對話用 LLM | 這裡 = embedding / context 分析
  "ollama": {
    "enabled": true,
    "primary": {
      "host": "http://localhost:11434",
      "model": "qwen3:14b",
      "embeddingModel": "qwen3-embedding:8b"
    },
    "failover": false,
    "thinkMode": false,
    "numPredict": 512,
    "timeout": 600000
  },

  // ── Safety（指令黑名單 / 檔案保護 / 執行授權）────────────────
  "safety": {
    "enabled": true,
    "selfProtect": true,
    "bash": {
      "blacklist": [
        "rm\\s+(-rf?|--recursive)\\s+[\\/~]",
        "mkfs",
        "dd\\s+if=",
        "chmod\\s+(-R\\s+)?777\\s+\\/",
        "chmod\\s+[ugoa]*\\+s\\s",
        "kill\\s+-9\\s+1$",
        "\\b(shutdown|reboot|poweroff)\\b",
        "systemctl\\s+(stop|disable)\\s",
        "\\$\\((curl|wget)\\s",
        "find\\s+.*-exec\\s",
        "git\\s+push\\s+.*--force.*\\s+(?:main|master)",
        "pm2\\s+(delete|kill)\\s+all",
        "^\\s*(env|printenv)\\s*$"
      ]
    },
    "filesystem": {
      "protectedPaths": [],
      "credentialPatterns": []
    },
    "execApproval": {
      "enabled": false,
      "dmUserId": "",                     // 需要確認的指令會 DM 此使用者
      "timeoutMs": 60000,
      "allowedPatterns": ["echo", "ls", "cat", "pwd", "date", "git status", "git log"]
    },
    // "collabConflict": { "enabled": true, "windowMs": 300000 },
    // "reversibility": { "threshold": 2 },
    "toolPermissions": {
      "defaultAllow": false
    }
  },

  // ── Workflow（Guardian / Fix Escalation / Wisdom / AIDocs）───
  "workflow": {
    "guardian":      { "enabled": true, "syncReminder": true, "fileTracking": true },
    "fixEscalation": { "enabled": true },
    "wisdomEngine":  { "enabled": true },
    "aidocs":        { "enabled": true, "contentGate": true }
  },

  // ── File Watcher（監控外部目錄變更，觸發事件）────────────────
  "fileWatcher": {
    "enabled": false,
    "watches": [
      // {
      //   "label": "my-notes",
      //   "path": "~/Notes",
      //   "debounceMs": 1500,
      //   "recursive": true,
      //   "ignoreDirs": [".obsidian", ".trash", ".git"]
      // }
    ]
  },

  // ── 帳號 & 配對 ────────────────────────────────────────────────
  "accounts": {
    "registrationMode": "open",            // open / invite / closed
    "defaultRole": "member",               // member / developer / admin
    "pairingEnabled": true,
    "pairingExpireMinutes": 5
  },

  // ── Rate Limit（每角色每分鐘請求上限）─────────────────────────
  "rateLimit": {
    "guest":          { "requestsPerMinute": 5 },
    "member":         { "requestsPerMinute": 30 },
    "developer":      { "requestsPerMinute": 60 },
    "admin":          { "requestsPerMinute": 120 },
    "platform-owner": { "requestsPerMinute": 300 }
  },

  // ── 預設 Agent（providerRouting 未指定時使用）─────────────────
  "defaultAgent": "default",

  // ── Dashboard ─────────────────────────────────────────────────
  "dashboard": {
    "enabled": true,
    "port": 8088
  },

  // ── Context Engineering（CE：decay → compaction → hard-stop）
  "contextEngineering": {
    "enabled": true,
    "strategies": {
      "compaction": {
        "enabled": true,
        "model": "sonnet",
        "triggerTurns": 20,
        "preserveRecentTurns": 5
      },
      "decay": {
        "enabled": true,
        "mode": "auto",
        "externalize": { "enabled": true }
      },
      "overflowHardStop": { "enabled": true }
    }
  },

  // ── Inbound History（requireMention 未觸發時記錄旁觀訊息）───
  "inboundHistory": {
    "enabled": true,
    "fullWindowHours": 24,
    "decayWindowHours": 168,
    "bucketBTokenCap": 600,
    "decayIITokenCap": 300,
    "inject": { "enabled": false }        // 預設關閉，確認 CE 後再開
  },

  // ── Subagent ──────────────────────────────────────────────────
  "subagents": {
    "maxConcurrent": 3,
    "defaultTimeoutMs": 120000,
    "defaultKeepSession": false
  },

  // ── Prompt Assembler（system prompt 模組化組裝）──────────────
  // 可用模組：identity / tools-usage / coding-rules / git-rules /
  //          output-format / discord-reply / memory-rules
  "promptAssembler": {
    "disabledModules": []
  },

  // ── MCP Servers（CatClaw 內建 MCP server 設定）──────────────
  // tier: public / elevated —— 決定需要哪種權限才能使用
  "mcpServers": {
    // "catclaw-discord": {
    //   "command": "node",
    //   "args": ["./dist/mcp/discord-server.js"],
    //   "env": { "DISCORD_TOKEN": "" },
    //   "tier": "public"
    // },
    // "computer-use": {
    //   "command": "node",
    //   "args": ["./mcp/computer-use/dist/index.js"],
    //   "env": {
    //     "COMPUTER_USE_ALLOWED_WINDOWS": "*",
    //     "COMPUTER_USE_MAX_SCREENSHOT_WIDTH": "1024",
    //     "COMPUTER_USE_HISTORY_DIR": "/tmp/computer-use-history"
    //   },
    //   "tier": "elevated"
    // },
    // "playwright": {
    //   "command": "node",
    //   "args": ["./mcp/playwright/dist/index.js"],
    //   "env": {
    //     "PLAYWRIGHT_HEADLESS": "true",
    //     "PLAYWRIGHT_BROWSER": "chromium",
    //     "PLAYWRIGHT_VIEWPORT": "1280x720"
    //   },
    //   "tier": "elevated"
    // }
  },

  // ── Bot Circuit Breaker（Discord API 異常時自動斷路）─────────
  "botCircuitBreaker": {
    "enabled": false
  }

  // ── 重啟上線通知（可選）──────────────────────────────────────
  // "restartNotify": {
  //   "enabled": true,
  //   "channels": ["頻道ID"],              // 必須明確指定，不設 = 不通知
  //   "showPendingTasks": true
  // }
}
