// catclaw 設定檔範本（JSONC 格式，支援 // 註解）
// 複製此檔為 ~/.catclaw/catclaw.json 後修改
// 路徑控制請改用環境變數（CATCLAW_CONFIG_DIR / CATCLAW_WORKSPACE / CATCLAW_CLAUDE_BIN）
{
  // ── Discord 連線與權限 ─────────────────────────────────────────
  "discord": {
    // Discord Bot Token（從 Developer Portal 取得）
    "token": "",

    // DM 私訊設定
    "dm": {
      "enabled": true
    },

    // Per-guild 權限設定
    // 繼承鏈：Thread → Parent Channel → Guild 預設
    "guilds": {
      // "<你的 Guild ID>": {
      //   "allow": true,
      //   "requireMention": true,
      //   "allowBot": false,
      //   "allowFrom": [],
      //   "channels": {
      //     "<頻道 ID>": { "allow": true, "requireMention": false },
      //     // autoThread: 每條訊息自動建立 Thread（適合多人討論頻道）
      //     "<thread 頻道 ID>": { "allow": true, "requireMention": false, "autoThread": true }
      //   }
      // }
    }
  },

  // ── 管理員設定（slash commands 權限）─────────────────────────
  "admin": {
    // 允許執行 /restart /reset-session /status 的 Discord user ID
    // 空陣列 = 拒絕所有人（建議至少填入自己的 ID）
    "allowedUserIds": []
  },

  // ── 全域設定 ───────────────────────────────────────────────────
  "turnTimeoutMs": 300000,         // 單次回應超時（毫秒），預設 5 分鐘
  "turnTimeoutToolCallMs": 480000, // tool_call 時延長超時（毫秒），預設 8 分鐘
  "sessionTtlHours": 168,          // Session 閒置超時（小時），預設 7 天
  "showToolCalls": "summary",      // all / summary / none
  "showThinking": false,
  "debounceMs": 500,
  "fileUploadThreshold": 4000,     // 超過此字數上傳為 .md（0 = 停用）
  "logLevel": "info",              // debug / info / warn / error / silent

  // ══════════════════════════════════════════════════════════════
  // V2 三層分離設定（推薦）
  // 格式：<provider>/<model>，如 "anthropic/claude-sonnet-4-6"
  // 認證放 auth-profile.json，模型目錄自動從內建 + 自訂合併
  // ══════════════════════════════════════════════════════════════

  // ── Agent 預設模型 ────────────────────────────────────────────
  "agentDefaults": {
    "model": {
      // primary：主要使用的模型（alias 或 "provider/model" 格式）
      "primary": "sonnet",
      // fallbacks：primary 不可用時依序嘗試
      "fallbacks": ["anthropic/claude-opus-4-6"]
    },
    // 模型對照表：key = "provider/model"，alias = 簡短名
    "models": {
      "anthropic/claude-sonnet-4-6": { "alias": "sonnet" },
      "anthropic/claude-opus-4-6": { "alias": "opus" },
      "anthropic/claude-haiku-4-5-20251001": { "alias": "haiku" }
      // "openai/gpt-4o": {},
      // "openai-codex/gpt-5.4": {},
      // "ollama/qwen3:8b": { "alias": "local" }
    }
  },

  // ── 模型目錄設定（可選）────────────────────────────────────────
  // 內建：anthropic、openai、openai-codex（自動載入）
  // 自訂 provider 在此新增，mode="merge" 與內建合併
  // "modelsConfig": {
  //   "mode": "merge",
  //   "providers": {
  //     "ollama": {
  //       "baseUrl": "http://localhost:11434",
  //       "api": "ollama",
  //       "models": [
  //         {
  //           "id": "qwen3:8b",
  //           "name": "Qwen3 8B",
  //           "reasoning": false,
  //           "input": ["text"],
  //           "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
  //           "contextWindow": 32768,
  //           "maxTokens": 8192
  //         }
  //       ]
  //     }
  //   }
  // },

  // ── 認證設定（可選，控制輪替順序和 cooldown）─────────────────
  // 實際 credential 放在 {workspace}/agents/default/auth-profile.json
  // 格式參考：
  // {
  //   "version": 1,
  //   "profiles": {
  //     "anthropic:default": { "type": "api_key", "provider": "anthropic", "key": "sk-ant-..." },
  //     "openai:primary":    { "type": "api_key", "provider": "openai", "key": "sk-..." },
  //     "openai-codex:default": { "type": "oauth", "provider": "openai-codex",
  //                               "access": "...", "refresh": "...", "expires": 1774019983859 }
  //   },
  //   "order": { "anthropic": ["anthropic:default"] }
  // }
  // "authConfig": {
  //   "order": { "anthropic": ["anthropic:default", "anthropic:backup"] },
  //   "cooldowns": { "billingBackoffHours": 5 }
  // },

  // ── Provider 路由 ──────────────────────────────────────────────
  // 優先序：channels > projects > roles > defaultProvider
  // 值可以是 alias 或 "provider/model" 格式
  "providerRouting": {
    "roles": {
      "default": "sonnet"
    }
    // 範例：特定頻道走不同模型
    // "channels": {
    //   "<頻道 ID>": "anthropic/claude-opus-4-6"
    // }
  },

  // ══════════════════════════════════════════════════════════════
  // V1 舊格式（保留相容，若有 agentDefaults 則以 V2 優先）
  // ══════════════════════════════════════════════════════════════
  "providers": {
    "claude": {
      "type": "claude",
      "mode": "token",
      "model": "claude-sonnet-4-6"
    }
  },

  // ── Session 持久化 ────────────────────────────────────────────
  "session": {
    "ttlHours": 168,
    "maxHistoryTurns": 50,
    "compactAfterTurns": 30,
    "persistPath": "~/.catclaw/data/sessions-v2"
  },

  // ── Context Engineering（CE）─────────────────────────────────────
  // 三段策略：decay → compaction → overflow-hard-stop
  // 執行順序固定，每次 build 都跑
  "contextEngineering": {
    "enabled": true,
    // "toolBudget": {
    //   "resultTokenCap": 0,     // 單一工具結果 token 上限（0 = 無限制；per-tool resultTokenCap 仍生效）
    //   "toolTimeoutMs": 0       // 全域工具逾時（0 = 無限制；per-tool timeoutMs 仍生效）
    // },
    "strategies": {
      "decay": {
        "enabled": true,
        "mode": "auto",            // discrete / continuous / time-aware / auto
        "baseDecay": 0.3,          // 指數衰減係數
        "referenceIntervalSec": 60,
        "tempoRange": [0.5, 2.0],
        "externalize": {
          "enabled": true,
          "triggerLevel": 2,       // L1→L2 時外部化
          "minTokens": 300,        // 最小 token 閾值
          "ttlDays": 14            // 外部檔案保留天數
        }
      },
      "compaction": {
        "enabled": true,
        "model": "claude-haiku-4-5-20251001",  // 壓縮用輕量模型
        "triggerTokens": 20000,    // token 超過此值觸發 LLM 摘要
        "preserveRecentTurns": 8   // 保留最近 N 輪不壓縮
      },
      "overflowHardStop": {
        "enabled": true,
        "hardLimitUtilization": 0.95  // 最後防線：token > window × 0.95 時緊急截斷
      }
    }
  },

  // ── Inbound History（requireMention 未觸發時記錄旁觀訊息）────────
  "inboundHistory": {
    "enabled": true,
    "fullWindowHours": 24,
    "decayWindowHours": 168,
    "bucketBTokenCap": 600,
    "decayIITokenCap": 300,
    "inject": { "enabled": false }  // 預設關閉，確認 CE 後再開
  },

  // ── Ollama（本地語意處理：原子記憶萃取 + 向量語意搜尋）────────────
  // 這是記憶系統的本地後端，與 providers 的 ollama LLM 用途不同
  // providers.ollama-* = 對話用 LLM | 這裡 = embedding / context 分析
  "ollama": {
    "enabled": false,
    "primary": {
      "host": "http://localhost:11434",
      "model": "qwen3:14b",
      "embeddingModel": "qwen3-embedding:8b"
    },
    "failover": false,
    "thinkMode": false,
    "numPredict": 512,
    "timeout": 60000
  },

  // ── 多 Agent ──────────────────────────────────────────────────
  // 定義具名 agent，可在 providerRouting 或 cron job 中引用
  // 每個 agent 繼承全域設定，可覆寫 provider / systemPrompt
  "agents": {
    // 主要對話 agent（預設）
    "default": {
      "provider": "claude-oauth",
      "systemPrompt": "你是 catclaw，一個整合 Discord 的 AI 助手。"
    }
    // 範例：獨立 agent 給特定頻道或排程任務使用
    // "helper": {
    //   "provider": "ollama-local",
    //   "systemPrompt": "你是一個輕量助理，負責快速查詢和簡短回答。"
    // }
  },

  // ── Subagent 設定 ─────────────────────────────────────────────
  "subagents": {
    // 同一 parent session 最多同時執行幾個子 agent
    "maxConcurrent": 3,
    // 子 agent 預設逾時毫秒
    "defaultTimeoutMs": 120000,
    // 完成後是否保留子 session（mode:session 自動 true）
    "defaultKeepSession": false
  },

  // ── 帳號管理 ──────────────────────────────────────────────────
  "accounts": {
    "registrationMode": "open",  // open / invite / closed
    "defaultRole": "member",     // member / developer / admin
    "pairingEnabled": true,
    "pairingExpireMinutes": 5
  },

  // ── 預設 Agent ────────────────────────────────────────────────────
  // providerRouting 未指定時使用此 agent
  "defaultAgent": "default",

  // ── 記憶系統 ──────────────────────────────────────────────────────
  "memory": {
    "enabled": true,
    "root": "",                       // 空字串 = 用 CATCLAW_WORKSPACE
    "vectorDbPath": "~/.catclaw/_vectordb",
    "contextBudget": 3000,
    "contextBudgetRatio": { "global": 1, "project": 1, "account": 1 },
    "writeGate": { "enabled": true, "dedupThreshold": 0.8 },
    "recall": {
      "triggerMatch": true,
      "vectorSearch": true,
      "relatedEdgeSpreading": true,
      "vectorMinScore": 0.35,
      "vectorTopK": 10,
      "llmSelect": false,
      "llmSelectMax": 5
    },
    "extract": { "enabled": true, "perTurn": true, "onSessionEnd": true, "maxItemsPerTurn": 3 }
  },

  // ── 記憶管線（embedding / extraction / reranker 後端）────────────
  "memoryPipeline": {
    "embedding": {
      "provider": "ollama",
      "model": "qwen3-embedding:8b",
      "host": "http://localhost:11434"
    },
    "extraction": {
      "provider": "ollama",
      "model": "qwen3:14b",
      "host": "http://localhost:11434"
    },
    "reranker": { "provider": "none", "model": "" }
  },

  // ── Dashboard ─────────────────────────────────────────────────────
  "dashboard": {
    "enabled": true,
    "port": 8088
  },

  // ── Rate Limit（每分鐘請求上限，依角色）──────────────────────────
  "rateLimit": {
    "guest":          { "requestsPerMinute": 5 },
    "member":         { "requestsPerMinute": 30 },
    "developer":      { "requestsPerMinute": 60 },
    "admin":          { "requestsPerMinute": 120 },
    "platform-owner": { "requestsPerMinute": 300 }
  },

  // ── Workflow（Guardian / Fix Escalation / AIDocs）────────────────
  "workflow": {
    "guardian": { "enabled": false, "syncReminder": true, "fileTracking": true },
    "fixEscalation": { "enabled": false },
    "wisdomEngine": { "enabled": false },
    "aidocs": { "enabled": false, "contentGate": true }
  },

  // ── Bot Circuit Breaker（Discord API 異常時自動斷路）─────────────
  "botCircuitBreaker": {
    "enabled": false
  },

  // ── 重啟上線通知 ─────────────────────────────────────────────────
  // "restartNotify": {
  //   "enabled": true,
  //   "channels": ["頻道ID"],  // 必須明確指定，不設 = 不通知
  //   "showPendingTasks": true
  // },

  // ── MCP Servers（CatClaw 內建 MCP server 設定）──────────────────
  // "mcpServers": {
  //   "catclaw-discord": {
  //     "command": "node",
  //     "args": ["./dist/mcp/discord-server.js"],
  //     "env": { "DISCORD_TOKEN": "<你的 bot token>" },
  //     "tier": "public"
  //   }
  // },

  // ── Safety（Sprint 4 新增）────────────────────────────────────────
  // "safety": {
  //   "enabled": true,
  //   "selfProtect": true,
  //   "bash": { "blacklist": ["rm\\s+(-rf?)\\s+[\\/~]"] },
  //   "filesystem": { "protectedPaths": [], "credentialPatterns": [] },
  //   "execApproval": { "enabled": false, "dmUserId": "", "timeoutMs": 60000 },
  //   // 協作衝突偵測：多人同頻道同時編輯同一檔案時發出警告
  //   "collabConflict": {
  //     "enabled": true,       // 是否啟用，預設 true
  //     "windowMs": 300000     // 偵測窗口毫秒，預設 5 分鐘
  //   },
  //   // 可逆性評估：tool 操作風險評分，超過門檻觸發警告
  //   "reversibility": {
  //     "threshold": 2         // 0-3，>= 此值觸發警告（預設 2）
  //   },
  //   "toolPermissions": { "defaultAllow": false }
  // },

  // ── Prompt Assembler（Sprint 3 新增）─────────────────────────────
  // 控制 system prompt 模組化組裝
  // "promptAssembler": {
  //   // 要停用的內建模組名稱
  //   // 可用模組：identity / tools-usage / coding-rules / git-rules /
  //   //          output-format / discord-reply / memory-rules
  //   "disabledModules": []
  // },

  // ── 排程 ─────────────────────────────────────────────────────────
  // jobs 亦可寫在 data/cron-jobs.json，此處 jobs 陣列優先
  "cron": {
    "enabled": false,
    "maxConcurrentRuns": 1,
    // subagent 任務預設使用的 accountId（不填預設 _cron）
    "defaultAccountId": "_cron",
    // subagent 任務預設 provider（不填則由 providerRouting 決定）
    "defaultProvider": "claude-oauth",
    // 預設 agent ID（job 未指定 agentId 時歸屬此 agent）
    "defaultAgentId": "wendy",
    "jobs": [
      // action.type 可選：
      //   message  → 傳送靜態訊息到指定頻道
      //   command  → 執行 shell 指令
      //   subagent → 啟動 AI agent 執行任務，結果回報到 notify 頻道
      //
      // 每個 job 可帶 "agentId": "wendy" 指定所屬 agent（/cron skill 建立時自動帶入）
      //
      // 範例：每天早上 9 點讓 AI 整理當日摘要
      // {
      //   "name": "daily-summary",
      //   "cron": "0 9 * * *",
      //   "action": {
      //     "type": "subagent",
      //     "task": "列出今天需要注意的事項並整理成摘要",
      //     "provider": "claude-oauth",      // 不填則用 defaultProvider
      //     "timeoutMs": 120000,
      //     "notify": "<Discord 頻道 ID>" // 任務完成後發送結果
      //   }
      // },
      //
      // 範例：每小時執行 shell 指令
      // {
      //   "name": "hourly-check",
      //   "cron": "0 * * * *",
      //   "action": {
      //     "type": "command",
      //     "command": "echo 'heartbeat'"
      //   }
      // }
    ]
  }
}
