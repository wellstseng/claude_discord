// catclaw 設定檔範本（JSONC 格式，支援 // 註解）
// 複製此檔為 ~/.catclaw/catclaw.json 後修改
// 路徑控制請改用環境變數（CATCLAW_CONFIG_DIR / CATCLAW_WORKSPACE / CATCLAW_CLAUDE_BIN）
{
  // ── Discord 連線與權限 ─────────────────────────────────────────
  "discord": {
    // Discord Bot Token（從 Developer Portal 取得）
    "token": "",

    // DM 私訊設定
    "dm": {
      "enabled": true
    },

    // Per-guild 權限設定
    // 繼承鏈：Thread → Parent Channel → Guild 預設
    "guilds": {
      // "<你的 Guild ID>": {
      //   "allow": true,
      //   "requireMention": true,
      //   "allowBot": false,
      //   "allowFrom": [],
      //   "channels": {
      //     "<頻道 ID>": { "allow": true, "requireMention": false }
      //   }
      // }
    }
  },

  // ── 管理員設定（slash commands 權限）─────────────────────────
  "admin": {
    // 允許執行 /restart /reset-session /status 的 Discord user ID
    // 空陣列 = 拒絕所有人（建議至少填入自己的 ID）
    "allowedUserIds": []
  },

  // ── 全域設定 ───────────────────────────────────────────────────
  "turnTimeoutMs": 300000,         // 單次回應超時（毫秒），預設 5 分鐘
  "turnTimeoutToolCallMs": 480000, // tool_call 時延長超時（毫秒），預設 8 分鐘
  "sessionTtlHours": 168,          // Session 閒置超時（小時），預設 7 天
  "showToolCalls": "summary",      // all / summary / none
  "showThinking": false,
  "debounceMs": 500,
  "fileUploadThreshold": 4000,     // 超過此字數上傳為 .md（0 = 停用）
  "logLevel": "info",              // debug / info / warn / error / silent

  // ── Providers（LLM 提供者）───────────────────────────────────
  // type 可選：claude / openai-compat / codex-oauth / ollama
  // 若不填 type，系統依以下順序自動判斷：
  //   entry.wsUrl → openclaw | id=claude-api → claude
  //   id 含 ollama → ollama | entry.host/baseUrl → openai-compat
  //   entry.token（無 baseUrl）→ claude
  "providers": {
    // Claude API：token 使用 ${VAR} 語法引用環境變數
    // 需先設定環境變數 ANTHROPIC_TOKEN（export 或 .env）
    "claude-api": {
      "token": "${ANTHROPIC_TOKEN}",
      "model": "claude-sonnet-4-6"
    },

    // Codex OAuth：OpenAI Codex，使用 Responses API（/v1/responses）
    // 需先執行 `codex auth login` 產生 ~/.codex/auth.json
    // "codex": {
    //   "type": "codex-oauth",
    //   "model": "openai-codex/gpt-5.4",
    //   "oauthTokenPath": "~/.codex/auth.json"
    // },

    // OpenAI compat：任何相容 OpenAI /v1/chat/completions 的服務
    // "openai-local": {
    //   "type": "openai-compat",
    //   "baseUrl": "http://localhost:8080",
    //   "token": "sk-...",
    //   "model": "gpt-4o"
    // },

    // Ollama 本地 LLM：使用 /api/chat NDJSON 串流（非 OpenAI compat）
    // think: true 啟用 thinking 模式（qwen3 等支援的模型）
    // numPredict: 每次最大 token 數（預設 4096）
    // supportsToolUse: 不填時 init() 自動偵測（查 /api/show capabilities）
    // "ollama-local": {
    //   "type": "ollama",
    //   "host": "http://localhost:11434",
    //   "model": "qwen3:1.7b",
    //   "think": false,
    //   "numPredict": 4096
    // }
  },

  // ── Provider 路由 ──────────────────────────────────────────────
  // 優先序：channels > projects > roles > defaultProvider
  // roles.default 為全域預設（必填）
  "providerRouting": {
    "roles": {
      "default": "claude-api"
    }
    // 範例：特定頻道走 ollama
    // "channels": {
    //   "<頻道 ID>": "ollama-local"
    // }
  },

  // ── Session 持久化 ────────────────────────────────────────────
  "session": {
    "ttlHours": 168,
    "maxHistoryTurns": 50,
    "compactAfterTurns": 30,
    "persistPath": "~/.catclaw/data/sessions-v2"
  },

  // ── Context Engineering（CE）─────────────────────────────────────
  // model 只放在有實際呼叫 LLM 的策略（compaction）；
  // budgetGuard 和 slidingWindow 純邏輯計算，不需要 model
  "contextEngineering": {
    "enabled": true,
    "strategies": {
      "compaction": {
        "enabled": true,
        "model": "claude-haiku-4-5-20251001",  // 壓縮用輕量模型
        "triggerTurns": 20,
        "preserveRecentTurns": 5
      },
      "budgetGuard": {
        "enabled": true,
        "maxUtilization": 0.8   // token 使用率超過 80% 時觸發裁切
      },
      "slidingWindow": {
        "enabled": false        // 停用：與 compaction 二擇一
      }
    }
  },

  // ── Inbound History（requireMention 未觸發時記錄旁觀訊息）────────
  "inboundHistory": {
    "enabled": true,
    "fullWindowHours": 24,
    "decayWindowHours": 168,
    "bucketBTokenCap": 600,
    "decayIITokenCap": 300,
    "inject": { "enabled": false }  // 預設關閉，確認 CE 後再開
  },

  // ── Ollama（本地語意處理：原子記憶萃取 + 向量語意搜尋）────────────
  // 這是記憶系統的本地後端，與 providers 的 ollama LLM 用途不同
  // providers.ollama-* = 對話用 LLM | 這裡 = embedding / context 分析
  "ollama": {
    "enabled": false,
    "primary": {
      "host": "http://localhost:11434",
      "model": "qwen3:14b",
      "embeddingModel": "qwen3-embedding:8b"
    },
    "failover": false,
    "thinkMode": false,
    "numPredict": 512,
    "timeout": 60000
  },

  // ── 多 Agent ──────────────────────────────────────────────────
  // 定義具名 agent，可在 providerRouting 或 cron job 中引用
  // 每個 agent 繼承全域設定，可覆寫 provider / systemPrompt
  "agents": {
    // 主要對話 agent（預設）
    "default": {
      "provider": "claude-api",
      "systemPrompt": "你是 catclaw，一個整合 Discord 的 AI 助手。"
    }
    // 範例：獨立 agent 給特定頻道或排程任務使用
    // "helper": {
    //   "provider": "ollama-local",
    //   "systemPrompt": "你是一個輕量助理，負責快速查詢和簡短回答。"
    // }
  },

  // ── Subagent 設定 ─────────────────────────────────────────────
  "subagents": {
    // 同一 parent session 最多同時執行幾個子 agent
    "maxConcurrent": 3,
    // 子 agent 預設逾時毫秒
    "defaultTimeoutMs": 120000,
    // 完成後是否保留子 session（mode:session 自動 true）
    "defaultKeepSession": false
  },

  // ── 帳號管理 ──────────────────────────────────────────────────
  "accounts": {
    "registrationMode": "open",  // open / invite / closed
    "defaultRole": "member",     // member / developer / admin
    "pairingEnabled": true,
    "pairingExpireMinutes": 5
  },

  // ── 排程 ─────────────────────────────────────────────────────────
  // jobs 亦可寫在 data/cron-jobs.json，此處 jobs 陣列優先
  "cron": {
    "enabled": false,
    "maxConcurrentRuns": 1,
    // subagent 任務預設使用的 accountId（不填預設 _cron）
    "defaultAccountId": "_cron",
    // subagent 任務預設 provider（不填則由 providerRouting 決定）
    "defaultProvider": "claude-api",
    "jobs": [
      // action.type 可選：
      //   message  → 傳送靜態訊息到指定頻道
      //   command  → 執行 shell 指令
      //   subagent → 啟動 AI agent 執行任務，結果回報到 notify 頻道
      //
      // 範例：每天早上 9 點讓 AI 整理當日摘要
      // {
      //   "name": "daily-summary",
      //   "cron": "0 9 * * *",
      //   "action": {
      //     "type": "subagent",
      //     "task": "列出今天需要注意的事項並整理成摘要",
      //     "provider": "claude-api",      // 不填則用 defaultProvider
      //     "timeoutMs": 120000,
      //     "notify": "<Discord 頻道 ID>" // 任務完成後發送結果
      //   }
      // },
      //
      // 範例：每小時執行 shell 指令
      // {
      //   "name": "hourly-check",
      //   "cron": "0 * * * *",
      //   "action": {
      //     "type": "command",
      //     "command": "echo 'heartbeat'"
      //   }
      // }
    ]
  }
}
